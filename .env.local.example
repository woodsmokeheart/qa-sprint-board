# Postgres (Neon). UNPOOLED — для миграций/скриптов (scripts/migrate.ts).
DATABASE_URL=postgres://user:password@host/dbname
DATABASE_URL_UNPOOLED=postgres://user:password@host/dbname

# Jira Cloud
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_TOKEN=base64(email:api_token)

# Доступ к админке и защита крона
ADMIN_TOKEN=your-secret-token-here
CRON_SECRET=your-cron-secret-here

# Необязательно: лимит хранилища БД для виджета на дашборде (байты). По умолчанию 512 MB.
# DB_SIZE_LIMIT_BYTES=536870912
